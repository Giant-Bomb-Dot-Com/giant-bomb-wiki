# Personal prod-like wiki DB (copy to .env.me — gitignored)
# Used with: docker compose -f docker-compose.yml -f docker-compose.me.yml

MARIADB_DATABASE=wiki_db143
DB_NAME=wiki_db143
MW_DB_NAME=wiki_db143
# Writable debug log directory (matches /var/log/mediawiki in the wiki image)
MW_LOG_DIR=/var/log/mediawiki

# Optional: keep gb_api_dump on the small dev DB name when you still run api-dump tooling
# MARIADB_API_DUMP_DATABASE=gb_api_dump
