local p = {}

local cachedReviews = nil

function p.fetchReviews(frame)
    if cachedReviews then
        return cachedReviews
    end

    local guid = frame.args.guid or frame:getParent().args.guid
    if not guid or guid == "" then
        return {}
    end

    local allReviews = {}
    local offset = 0
    local limit = 50
    local hasNext = true
    local maxPages = 2

    while hasNext and (offset / limit) < maxPages do
        local data = mw.ext.gbenv.fetchUserReviews(guid, offset, limit)

        if data and data.results then
            for _, review in ipairs(data.results) do
                table.insert(allReviews, review)
            end
            if data.pagination and data.pagination.has_next then
                offset = offset + limit
            else
                hasNext = false
            end
        else
            hasNext = false
        end
    end

    cachedReviews = allReviews
    return cachedReviews
end

function p.renderSidebar(frame)

    local allReviews = p.fetchReviews(frame)

    local counts = { [5]=0, [4]=0, [3]=0, [2]=0, [1]=0 }
    local totalScore = 0
    local reviewCount = #allReviews

    for _, review in ipairs(allReviews) do
        local rawScore = tonumber(review.score) or 0
        local stars = math.max(1, math.min(5, math.floor(rawScore / 20)))
        counts[stars] = counts[stars] + 1
        totalScore = totalScore + stars
    end

    local avgScore = reviewCount > 0 and (totalScore / reviewCount) or 0

    local header = mw.html.create('div'):addClass('gb-sidebar-section-header'):wikitext('What the users think')
    
    local html = mw.html.create('div'):addClass('gb-sidebar-section-content')

    for i = 5, 1, -1 do
        local row = html:tag('div'):addClass('review-star-bar')
        row:tag('span'):wikitext(i .. ' ★ (' .. counts[i] .. ')')
        
        local barContainer = row:tag('div'):addClass('review-bar')
        local barWidth = reviewCount > 0 and (counts[i] / reviewCount * 100) or 0
        barContainer:tag('div'):addClass("review-fill"):css('width', barWidth .. '%')
    end

    local footer = html:tag('div'):addClass('gb-review-footer')
    local scoreColumn = footer:tag('div'):addClass('gb-review-score-column')

    local row = scoreColumn:tag('div'):addClass('gb-review-summary-row')
    row:tag('span'):addClass('gb-review-score-text'):wikitext(string.format("%.1f ", avgScore))

    local starScore = (avgScore / 5) * 100
    local starContainer = row:tag('div'):addClass('stars')
    for i = 5, 1, -1 do
        starContainer:tag('div'):addClass('star')
    end
    starContainer:tag('div'):addClass("star-cover"):css('width', starScore .. '%')

    scoreColumn:tag('div'):addClass('gb-review-subtext'):wikitext("Average score of " .. reviewCount .. " user reviews")
    footer:tag('div'):addClass('gb-review-button'):addClass('gb-button'):wikitext('[https://giantbomb.com/user-reviews/new Add new review]')

    return tostring(header) .. tostring(html)
end

function p.renderReviewContent(frame)
    local allReviews = p.fetchReviews(frame)

    local output = {}

    for _, review in ipairs(allReviews) do
        local reviewUrl = "https://giantbomb.com/" .. tostring(review.url or "")
        table.insert(output, '<div class="user-review">')
        table.insert(output, string.format("=== [%s %s] ===", reviewUrl, review.title or ""))
        
        local metaContainer = mw.html.create('div')
            :addClass('review-metadata')

        if review.owner and review.owner.avatar and review.owner.avatar.url then
            metaContainer:tag('span')
                :addClass('user-avatar-frame')
                :wikitext(review.owner.avatar.url)
        end

        local detailsStack = metaContainer:tag('div')
            :addClass('review-details-stack')
            
        local stars = math.max(1, math.min(5, math.floor((tonumber(review.score) or 0) / 20)))
        
        local starPercentage = (stars / 5) * 100
        
        local starContainer = detailsStack:tag('div'):addClass('stars')
        for i = 1, 5 do
            starContainer:tag('div'):addClass('star')
        end
        starContainer:tag('div')
            :addClass("star-cover")
            :css('width', starPercentage .. '%')        

        local authorHtml = ""
        if review.owner and review.owner.username then             
            local userLink = "https://giantbomb.com/profile/" .. review.owner.username
            authorHtml = authorHtml .. " by " .. string.format("[%s %s]", userLink, review.owner.username) .. " on "
        end
        local date = review.publish_date and mw.language.getContentLanguage():formatDate('F, j Y', review.publish_date) or ""
        authorHtml = authorHtml .. date
        detailsStack:tag('span'):addClass('author-text'):wikitext(authorHtml)
            
        table.insert(output, tostring(metaContainer))

        local excerptContainer = mw.html.create('p')
            :addClass('review-excerpt')
            :wikitext(review.excerpt)
            
        table.insert(output, tostring(excerptContainer))
        table.insert(output, '</div>')
    end

    local sidebarHtml = p.renderSidebar(frame)
    table.insert(output, 1, sidebarHtml)
    table.insert(output, 2, "__TOC__")

    return table.concat(output, "\n")
end

return p
