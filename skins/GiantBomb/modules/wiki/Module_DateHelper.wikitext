local p = {}
local pageCache = {}

-- check arguments from invoke call before checking parent template arguments with preprocess as fallback
local function getArgs(frame)
    local args = frame.args
    if (args.ReleaseDateType and args.ReleaseDateType ~= "") or (args.ReleaseDate and args.ReleaseDate ~= "") then
        return args
    end

    local parent = frame:getParent()
    if parent and ((parent.args.ReleaseDateType and parent.args.ReleaseDateType ~= "") or (parent.args.ReleaseDate and parent.args.ReleaseDate ~= "")) then
        return parent.args
    end

    return {
        ReleaseDateType = frame:preprocess('{{{ReleaseDateType|}}}'),
        ReleaseDate = frame:preprocess('{{{ReleaseDate|}}}'),
        MonthPart = frame:preprocess('{{{MonthPart|}}}'),
        MonthYearPart = frame:preprocess('{{{MonthYearPart|}}}'),
        QuarterPart = frame:preprocess('{{{QuarterPart|}}}'),
        QuarterYearPart = frame:preprocess('{{{QuarterYearPart|}}}'),
        YearPart = frame:preprocess('{{{YearPart|}}}'),
    }
end

-- fetches value of given param from the template's smw data
local function fetchValue(paramName)
    local pageName = mw.title.getCurrentTitle().prefixedText
    local title = mw.title.new(pageName)
    if not title then return nil end
    
    local content = title:getContent()
    if not content then return nil end

    local pattern = "|%s*" .. paramName .. "%s*=%s*([^|%}%c]+)"
    local value = content:match(pattern)
    return value and mw.text.trim(value) or ""
end

function p.getExistingValue(frame)
    local param = frame.args[1]
    return fetchValue(param) or ""
end

-- determines if legacy date for displaying warning in form
function p.displayLegacyWarning(frame)
    local releaseDateType = fetchValue("ReleaseDateType")
    local releaseDate = fetchValue("ReleaseDate")
    
    -- empty date is not a legacy date
    if releaseDate == nil or releaseDate == "" then
        return ""
    end

    -- filled date and Full date type is not a legacy date
    if releaseDate ~= nil and releaseDateType == "Full" then
        return ""
    end
    
    -- filled date and full date type is not Full is a legacy date
    if releaseDate ~= "" and releaseDate ~= nil and (releaseDateType == nil or releaseDateType == "" or releaseDateType ~= "Full") then
        return "true"
    end
    
    -- don't show warning otherwise
    return ""
end

-- Returns the string formatted date using smw date parts
function p.getDisplayDateFromParts(frame)
    local args = getArgs(frame)

    local dateType = args.ReleaseDateType or ""
    
    if dateType == "Full" then
        return mw.getLanguage('en'):formatDate('F j, Y', args.ReleaseDate) or ""
        
    elseif dateType == "Month" then
        return mw.getLanguage('en'):formatDate('F Y', args.MonthYearPart .. "-" .. args.MonthPart)
        
    elseif dateType == "Quarter" then
        return args.QuarterPart .. " " .. (args.QuarterYearPart or "")
        
    elseif dateType == "Year" then
        return args.YearPart or ""
        
    else
        return args.ReleaseDate or ""
    end
end

-- Returns the string formatted date from iso date - used by Template:DateDisplay
function p.getDisplayDateFromISO(frame)
    local args = getArgs(frame)
    
    local dateStr = args.ReleaseDate or ""
    local dateType = args.ReleaseDateType or ""
    
    if dateStr == "" then return "" end

    local year, month = dateStr:match("^(%d%d%d%d)[/-](%d%d)")
    if not year or not month then 
        return dateStr
    end

    if dateType == "Quarter" then
        local qMap = { ["01"]="Q1", ["04"]="Q2", ["07"]="Q3", ["10"]="Q4" }
        return (qMap[month] or "Q1") .. " " .. year
    end

    if dateType == "Month" then
        return mw.getLanguage('en'):formatDate('F Y', dateStr)
    end
    
    if dateType == "Year" then 
        return year
    end
    
    return mw.getLanguage('en'):formatDate('F j, Y', dateStr)
end

-- Returns ISO formatted date using smw date parts
function p.getISODateFromParts(frame)
    local args = getArgs(frame)
    
    local dateType = args.ReleaseDateType or ""
    
    if dateType == "Full" then
        return args.releaseDate or ""
        
    elseif dateType == "Month" then
        local mMap = {
            January="01", February="02", March="03", April="04", May="05", June="06",
            July="07", August="08", September="09", October="10", November="11", December="12"
        }
        local year = args.MonthYearPart or ""
        local month = mMap[args.MonthPart] or "01"
        return year .. "-" .. month
        
    elseif dateType == "Quarter" then
        local qMap = { Q1="01", Q2="04", Q3="07", Q4="10" }
        local year = args.QuarterYearPart or ""
        local month = qMap[args.QuarterPart] or "01"
        return year .. "-" .. month
        
    elseif dateType == "Year" then
        return args.YearPart or ""
        
    else
        return args.ReleaseDate or ""
    end
end

-- store iso and display date formats in cache for a single page render
local function constructDates(frame)
    if pageCache.iso and pageCache.iso ~= "" then return end 

    local args = getArgs(frame)
    
    local dateType = args.ReleaseDateType or ""
    local legacyDate = args.ReleaseDate or ""

    local iso = ""
    local display = ""

    -- fuzzy dates have a date type
    if dateType ~= "" then
        -- account for legacy dates with date type
        if dateType ~= "Full" and legacyDate ~= "" and legacyDate ~= nil then
            iso = legacyDate
            display = p.getDisplayDateFromISO(frame)
        else        
            iso = p.getISODateFromParts(frame)
            display = p.getDisplayDateFromParts(frame)
        end
    
    -- account for legacy dates without date type
    elseif legacyDate ~= "" then
        iso = legacyDate
        display = p.getDisplayDateFromISO(frame)
    end

    pageCache.iso = iso
    pageCache.display = display
end

function p.loadDates(frame)
    constructDates(frame)
    return ""
end

function p.getISO(frame)
    if not pageCache.iso or pageCache.iso == "" then constructDates(frame) end
    return pageCache.iso or ""
end

function p.getDisplay(frame)
    if not pageCache.iso or pageCache.iso == "" then constructDates(frame) end
    return pageCache.display or ""
end

function p.hasDate(frame)
    if not pageCache.iso or pageCache.iso == "" then constructDates(frame) end
    
    if (pageCache.iso and pageCache.iso ~= "") or (pageCache.display and pageCache.display ~= "") then
        return "true"
    end
    return ""
end

return p